</span><span>;</span><br><span>  color: #f7f3ec;</span><br><span>  font-size: </span><span class="ͼb">0.9</span><span class="ͼ8">rem</span><span>;</span><br><span>  text-transform: </span><span class="ͼb">uppercase</span><span>;</span><br><span>  letter-spacing: </span><span class="ͼb">0.09</span><span class="ͼ8">em</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">video-caption</span><span> {</span><br><span>  font-size: </span><span class="ͼb">0.85</span><span class="ͼ8">rem</span><span>;</span><br><span>  color: </span><span class="ͼ8">var</span><span>(</span><span class="ͼe">--muted</span><span>);</span><br><span>  margin-top: </span><span class="ͼb">10</span><span class="ͼ8">px</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">video-actions</span><span> {</span><br><span>  margin-top: </span><span class="ͼb">10</span><span class="ͼ8">px</span><span>;</span><br><span>  display: </span><span class="ͼb">flex</span><span>;</span><br><span>  gap: </span><span class="ͼb">10</span><span class="ͼ8">px</span><span>;</span><br><span>}</span><br><br><span class="ͼ6">/* Powder cards */</span><br><br><span>.</span><span class="ͼd">powder-grid</span><span> {</span><br><span>  display: </span><span class="ͼb">grid</span><span>;</span><br><span>  grid-template-columns: </span><span class="ͼ8">repeat</span><span>(</span><span class="ͼb">2</span><span>, </span><span class="ͼ8">minmax</span><span>(</span><span class="ͼb">0</span><span>, </span><span class="ͼb">1</span><span class="ͼ8">fr</span><span>));</span><br><span>  gap: </span><span class="ͼb">24</span><span class="ͼ8">px</span><span>;</span><br><span>  margin-top: </span><span class="ͼb">28</span><span class="ͼ8">px</span><span>;</span><br><span>  margin-bottom: </span><span class="ͼb">10</span><span class="ͼ8">px</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">powder-card</span><span> {</span><br><span>  text-align: </span><span class="ͼb">center</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">powder-bag</span><span> {</span><br><span>  width: </span><span class="ͼb">160</span><span class="ͼ8">px</span><span>;</span><br><span>  height: </span><span class="ͼb">160</span><span class="ͼ8">px</span><span>;</span><br><span>  margin: </span><span class="ͼb">0</span><span> </span><span class="ͼb">auto</span><span> </span><span class="ͼb">12</span><span class="ͼ8">px</span><span>;</span><br><span>  border-radius: </span><span class="ͼb">18</span><span class="ͼ8">px</span><span>;</span><br><span>  box-shadow: </span><span class="ͼ8">var</span><span>(</span><span class="ͼe">--shadow-soft</span><span>);</span><br><span>  border: </span><span class="ͼb">1</span><span class="ͼ8">px</span><span> </span><span class="ͼb">solid</span><span> </span><span class="ͼ8">rgba</span><span>(</span><span class="ͼb">0</span><span>, </span><span class="ͼb">0</span><span>, </span><span class="ͼb">0</span><span>, </span><span class="ͼb">0.07</span><span>);</span><br><span>}</span><br><br><span>.</span><span class="ͼd">powder-bag-white</span><span> {</span><br><span>  background: </span><span class="ͼ8">linear-gradient</span><span>(</span><span class="ͼb">140</span><span class="ͼ8">deg</span><span>, #fdfcf9, #e8e3d7);</span><br><span>}</span><br><br><span>.</span><span class="ͼd">powder-bag-color</span><span> {</span><br><span>  background: </span><span class="ͼ8">linear-gradient</span><span>(</span><span class="ͼb">140</span><span class="ͼ8">deg</span><span>, #f3d4af, #e0b18a);</span><br><span>}</span><br><br><span>.</span><span class="ͼd">powder-card</span><span> </span><span class="ͼg">h3</span><span> {</span><br><span>  font-family: </span><span class="ͼ8">var</span><span>(</span><span class="ͼe">--font-serif</span><span>);</span><br><span>  margin-bottom: </span><span class="ͼb">4</span><span class="ͼ8">px</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">price</span><span> {</span><br><span>  margin-top: </span><span class="ͼb">0</span><span>;</span><br><span>  margin-bottom: </span><span class="ͼb">12</span><span class="ͼ8">px</span><span>;</span><br><span>}</span><br><br><span class="ͼ6">/* Story */</span><br><br><span>.</span><span class="ͼd">story-grid</span><span> {</span><br><span>  display: </span><span class="ͼb">grid</span><span>;</span><br><span>  grid-template-columns: </span><span class="ͼ8">minmax</span><span>(</span><span class="ͼb">0</span><span>, </span><span class="ͼb">1.2</span><span class="ͼ8">fr</span><span>) </span><span class="ͼ8">minmax</span><span>(</span><span class="ͼb">0</span><span>, </span><span class="ͼb">1</span><span class="ͼ8">fr</span><span>);</span><br><span>  gap: </span><span class="ͼb">24</span><span class="ͼ8">px</span><span>;</span><br><span>  align-items: </span><span class="ͼb">start</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">paper-story</span><span> </span><span class="ͼg">p</span><span> {</span><br><span>  margin: </span><span class="ͼb">0</span><span>;</span><br><span>  font-family: </span><span class="ͼ8">var</span><span>(</span><span class="ͼe">--font-serif</span><span>);</span><br><span>  font-size: </span><span class="ͼb">1</span><span class="ͼ8">rem</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">paper-photo</span><span> .</span><span class="ͼd">photo-placeholder</span><span> {</span><br><span>  border-radius: </span><span class="ͼb">10</span><span class="ͼ8">px</span><span>;</span><br><span>  background: #c6b8a7;</span><br><span>  height: </span><span class="ͼb">180</span><span class="ͼ8">px</span><span>;</span><br><span>  display: </span><span class="ͼb">flex</span><span>;</span><br><span>  align-items: </span><span class="ͼb">center</span><span>;</span><br><span>  justify-content: </span><span class="ͼb">center</span><span>;</span><br><span>  color: #f9f4ed;</span><br><span>  font-size: </span><span class="ͼb">0.9</span><span class="ͼ8">rem</span><span>;</span><br><span>}</span><br><br><span class="ͼ6">/* Final CTA */</span><br><br><span>.</span><span class="ͼd">section-final</span><span> {</span><br><span>  text-align: </span><span class="ͼb">center</span><span>;</span><br><span>  padding-bottom: </span><span class="ͼb">90</span><span class="ͼ8">px</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">final-inner</span><span> </span><span class="ͼg">h2</span><span> {</span><br><span>  font-family: </span><span class="ͼ8">var</span><span>(</span><span class="ͼe">--font-serif</span><span>);</span><br><span>  font-size: </span><span class="ͼb">2</span><span class="ͼ8">rem</span><span>;</span><br><span>  margin-bottom: </span><span class="ͼb">6</span><span class="ͼ8">px</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">final-inner</span><span> </span><span class="ͼg">p</span><span> {</span><br><span>  margin-top: </span><span class="ͼb">0</span><span>;</span><br><span>  margin-bottom: </span><span class="ͼb">14</span><span class="ͼ8">px</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">final-note</span><span> {</span><br><span>  font-size: </span><span class="ͼb">0.8</span><span class="ͼ8">rem</span><span>;</span><br><span>  color: </span><span class="ͼ8">var</span><span>(</span><span class="ͼe">--muted</span><span>);</span><br><span>  margin-top: </span><span class="ͼb">10</span><span class="ͼ8">px</span><span>;</span><br><span>}</span><br><br><span class="ͼ6">/* Footer */</span><br><br><span>.</span><span class="ͼd">site-footer</span><span> {</span><br><span>  border-top: </span><span class="ͼb">1</span><span class="ͼ8">px</span><span> </span><span class="ͼb">solid</span><span> </span><span class="ͼ8">var</span><span>(</span><span class="ͼe">--border-light</span><span>);</span><br><span>  background: #e7dfd4;</span><br><span>  padding: </span><span class="ͼb">16</span><span class="ͼ8">px</span><span> </span><span class="ͼb">0</span><span>;</span><br><span>  font-size: </span><span class="ͼb">0.8</span><span class="ͼ8">rem</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">footer-inner</span><span> {</span><br><span>  display: </span><span class="ͼb">flex</span><span>;</span><br><span>  justify-content: </span><span class="ͼb">space-between</span><span>;</span><br><span>  align-items: </span><span class="ͼb">center</span><span>;</span><br><span>  gap: </span><span class="ͼb">10</span><span class="ͼ8">px</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">footer-links</span><span> {</span><br><span>  display: </span><span class="ͼb">flex</span><span>;</span><br><span>  flex-wrap: </span><span class="ͼb">wrap</span><span>;</span><br><span>  gap: </span><span class="ͼb">8</span><span class="ͼ8">px</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">footer-links</span><span> </span><span class="ͼg">a</span><span> {</span><br><span>  color: </span><span class="ͼ8">var</span><span>(</span><span class="ͼe">--muted</span><span>);</span><br><span>  text-decoration: </span><span class="ͼb">none</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">footer-links</span><span> </span><span class="ͼg">a</span><span>:</span><span class="ͼd">hover</span><span> {</span><br><span>  color: </span><span class="ͼ8">var</span><span>(</span><span class="ͼe">--text</span><span>);</span><br><span>}</span><br><br><span class="ͼ6">/* Responsive */</span><br><br><span class="ͼ8">@media</span><span> (max-width: </span><span class="ͼb">800</span><span class="ͼ8">px</span><span>) {</span><br><span>  .</span><span class="ͼd">header-inner</span><span> {</span><br><span>    gap: </span><span class="ͼb">12</span><span class="ͼ8">px</span><span>;</span><br><span>  }</span><br><br><span>  .</span><span class="ͼd">nav</span><span> {</span><br><span>    display: </span><span class="ͼb">none</span><span>;</span><br><span>  }</span><br><br><span>  .</span><span class="ͼd">hero</span><span> </span><span class="ͼg">h1</span><span> {</span><br><span>    font-size: </span><span class="ͼb">2.1</span><span class="ͼ8">rem</span><span>;</span><br><span>  }</span><br><br><span>  .</span><span class="ͼd">today-grid</span><span>,</span><br><span>  .</span><span class="ͼd">powder-grid</span><span>,</span><br><span>  .</span><span class="ͼd">story-grid</span><span> {</span><br><span>    grid-template-columns: </span><span class="ͼb">1</span><span class="ͼ8">fr</span><span>;</span><br><span>  }</span><br><br><span>  .</span><span class="ͼd">paper-video</span><span> .</span><span class="ͼd">video-placeholder</span><span> {</span><br><span>    height: </span><span class="ͼb">190</span><span class="ͼ8">px</span><span>;</span><br><span>  }</span><br><span>}</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
<hr data-start="12004" data-end="12007">
<h2 data-start="12009" data-end="12045">3️⃣ Jak to dostaneš na <strong data-start="12035" data-end="12045">GitHub</strong></h2>
<ol data-start="12047" data-end="12463">
<li data-start="12047" data-end="12114">
<p data-start="12050" data-end="12114">Na GitHubu klikni <strong data-start="12068" data-end="12086">New repository</strong> → název třeba <code data-start="12101" data-end="12113">washerlife</code>.</p>
</li>
<li data-start="12115" data-end="12162">
<p data-start="12118" data-end="12162">Zaškrtni „Public“, nic jiného řešit nemusíš.</p>
</li>
<li data-start="12163" data-end="12463">
<p data-start="12166" data-end="12294">Repo si stáhni (buď přes <code data-start="12191" data-end="12202">git clone</code> v terminálu, nebo stáhni ZIP a pak nahraj soubory přes webové UI – klidně webová varianta):</p>
<ul data-start="12298" data-end="12463">
<li data-start="12298" data-end="12311">
<p data-start="12300" data-end="12311">otevři repo</p>
</li>
<li data-start="12315" data-end="12344">
<p data-start="12317" data-end="12344"><strong data-start="12317" data-end="12344">Add file → Upload files</strong></p>
</li>
<li data-start="12348" data-end="12434">
<p data-start="12350" data-end="12434">nahraj <code data-start="12357" data-end="12369">index.html</code>, <code data-start="12371" data-end="12383">styles.css</code> (+ obrázek <code data-start="12395" data-end="12416">washerlife-hero.jpg</code>, až ho budeš mít)</p>
</li>
<li data-start="12438" data-end="12463">
<p data-start="12440" data-end="12463">dole <strong data-start="12445" data-end="12463">Commit changes</strong></p>
</li>
</ul>
</li>
</ol>
<hr data-start="12465" data-end="12468">
<h2 data-start="12470" data-end="12506">4️⃣ Jak to připojíš ve <strong data-start="12496" data-end="12506">Vercel</strong></h2>
<ol data-start="12508" data-end="12776">
<li data-start="12508" data-end="12533">
<p data-start="12511" data-end="12533">Přihlas se do Vercelu.</p>
</li>
<li data-start="12534" data-end="12566">
<p data-start="12537" data-end="12566">Klikni <strong data-start="12544" data-end="12565">Add New → Project</strong>.</p>
</li>
<li data-start="12567" data-end="12610">
<p data-start="12570" data-end="12610">V seznamu repozitářů vyber <code data-start="12597" data-end="12609">washerlife</code>.</p>
</li>
<li data-start="12611" data-end="12754">
<p data-start="12614" data-end="12687">Vercel automaticky pozná, že je to <strong data-start="12649" data-end="12664">Static Site</strong> (žádný build command).</p>
<ul data-start="12691" data-end="12754">
<li data-start="12691" data-end="12720">
<p data-start="12693" data-end="12720">Build Command: nech prázdné</p>
</li>
<li data-start="12724" data-end="12754">
<p data-start="12726" data-end="12754">Output Directory: <code data-start="12744" data-end="12747">/</code> (root)</p>
</li>
</ul>
</li>
<li data-start="12755" data-end="12776">
<p data-start="12758" data-end="12776">Klikni <strong data-start="12765" data-end="12775">Deploy</strong>.</p>
</li>
</ol>
<p data-start="12778" data-end="12855">Po deploy bude web dostupný na adrese typu<br data-start="12820" data-end="12823">
<code data-start="12823" data-end="12854">https://washerlife.vercel.app</code>.</p>
<hr data-start="12857" data-end="12860">
<h2 data-start="12862" data-end="12912">5️⃣ Jak k tomu připojíš doménu <code data-start="12896" data-end="12912">washerlife.com</code></h2>
<ol data-start="12914" data-end="13313">
<li data-start="12914" data-end="12987">
<p data-start="12917" data-end="12987">Ve Vercelu v projektu → záložka <strong data-start="12949" data-end="12960">Domains</strong> → přidej <code data-start="12970" data-end="12986">washerlife.com</code>.</p>
</li>
<li data-start="12988" data-end="13034">
<p data-start="12991" data-end="13034">Vercel ti ukáže, jaké DNS záznamy nastavit.</p>
</li>
<li data-start="13035" data-end="13095">
<p data-start="13038" data-end="13095">Přejdi do <strong data-start="13048" data-end="13062">Websupport</strong> → DNS zóny pro <code data-start="13078" data-end="13094">washerlife.com</code>.</p>
</li>
<li data-start="13096" data-end="13242">
<p data-start="13099" data-end="13106">Nastav:</p>
<ul data-start="13110" data-end="13242">
<li data-start="13110" data-end="13151">
<p data-start="13112" data-end="13151">buď <strong data-start="13116" data-end="13125">CNAME</strong> z <code data-start="13128" data-end="13133">www</code> na ten Vercel URL</p>
</li>
<li data-start="13155" data-end="13242">
<p data-start="13157" data-end="13242">nebo A záznamy na IP od Vercelu (nebo nameservery, podle toho, co ti Vercel nabídne).</p>
</li>
</ul>
</li>
<li data-start="13243" data-end="13313">
<p data-start="13246" data-end="13313">Uložit → po propagaci DNS bude <code data-start="13277" data-end="13293">washerlife.com</code> ukazovat na Vercel.</p>
</li>
</ol>
<hr data-start="13315" data-end="13318">
<p data-start="13320" data-end="13350">Když chceš, v dalším kroku ti:</p>
<ul data-start="13352" data-end="13558" data-is-last-node="" data-is-only-node="">
<li data-start="13352" data-end="13413">
<p data-start="13354" data-end="13413">upravím kód tak, aby se ti snadno měnila <strong data-start="13395" data-end="13412">denní message</strong>,</p>
</li>
<li data-start="13414" data-end="13497">
<p data-start="13416" data-end="13497">vymyslíme, jak tam napojit skutečné <strong data-start="13452" data-end="13468">video pračky</strong> (YouTube / vlastní hosting),</p>
</li>
<li data-start="13498" data-end="13558" data-is-last-node="">
<p data-start="13500" data-end="13558" data-is-last-node="">a časem z toho uděláme opravdový malý e-shop místo mailto.</p>
</li>
</ul></div></div></div></div><div class="z-0 flex min-h-[46px] justify-start"><div class="touch:-me-2 touch:-ms-3.5 -ms-2.5 -me-1 flex flex-wrap items-center gap-y-4 p-1 select-none touch:w-[calc(100%+--spacing(3.5))] -mt-1 w-[calc(100%+--spacing(2.5))] duration-[1.5s] focus-within:transition-none hover:transition-none touch:pointer-events-auto pointer-events-none [mask-image:linear-gradient(to_right,black_33%,transparent_66%)] [mask-size:300%_100%] [mask-position:100%_0%] motion-safe:transition-[mask-position] group-hover/turn-messages:pointer-events-auto group-hover/turn-messages:[mask-position:0_0] group-focus-within/turn-messages:pointer-events-auto group-focus-within/turn-messages:[mask-position:0_0] has-data-[state=open]:pointer-events-auto has-data-[state=open]:[mask-position:0_0]" style="mask-position: 0% 0%;"><button class="text-token-text-secondary hover:bg-token-bg-secondary rounded-lg" aria-label="Copy" aria-pressed="false" data-testid="copy-turn-action-button" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-eri7ssmm.svg#ce3544" fill="currentColor"></use></svg></span></button><button class="text-token-text-secondary hover:bg-token-bg-secondary rounded-lg" aria-label="Good response" aria-pressed="false" data-testid="good-response-turn-action-button" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-eri7ssmm.svg#51753c" fill="currentColor"></use></svg></span></button><button class="text-token-text-secondary hover:bg-token-bg-secondary rounded-lg" aria-label="Bad response" aria-pressed="false" data-testid="bad-response-turn-action-button" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg